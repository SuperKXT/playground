{
	"name": "playground",
	"version": "1.0.0",
	"license": "MIT",
	"author": "Saad Khan",
	"type": "module",
	"scripts": {
		"lint": "eslint . --max-warnings=0 --fix && pnpm format && pnpm spellcheck",
		"format": "prettier --write --log-level silent .",
		"test": "vitest watch",
		"test-ui": "vitest --ui",
		"tsc": "tsc",
		"typecheck": "vitest typecheck",
		"wordle": "tsx ./scripts/wordle/wordle.ts",
		"kebab-rename": "tsx ./scripts/recursive-rename/recursive-rename.ts",
		"md-csv": "tsx ./scripts/md-links-to-csv/script.ts",
		"spellcheck": "cspell . --quiet",
		"diag": "tsc --extendedDiagnostics",
		"trace": "tsc --generateTrace ./trace && npx @typescript/analyze-trace trace"
	},
	"dependencies": {
		"chalk": "5.6.2",
		"dayjs": "1.11.21",
		"minimist-lite": "2.3.0",
		"prompt": "1.3.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@total-typescript/ts-reset": "0.6.1",
		"@type-challenges/utils": "0.1.1",
		"@types/eslint": "9.6.1",
		"@types/node": "26.0.0",
		"@types/prompt": "1.1.9",
		"@typescript/analyze-trace": "0.11.0",
		"@vitest/coverage-v8": "4.1.9",
		"@vitest/eslint-plugin": "1.6.20",
		"@vitest/ui": "4.1.9",
		"cspell": "10.0.1",
		"eslint": "10.5.0",
		"eslint-import-resolver-typescript": "4.4.5",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-n": "18.1.0",
		"eslint-plugin-only-warn": "1.2.1",
		"eslint-plugin-unused-imports": "4.4.1",
		"globals": "17.6.0",
		"prettier": "3.8.4",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"typescript-eslint": "8.61.1",
		"vitest": "4.1.9"
	},
	"engines": {
		"node": ">=24.14.0"
	},
	"packageManager": "pnpm@11.6.0"
}
